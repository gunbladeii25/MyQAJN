OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
CHROMA_DB_PATH=./rag/chroma_db
KNOWLEDGE_BASE_PATH=./rag/knowledge_base
MODELS_PATH=./models

# ── Google Drive — Pemeriksaan JN (syor documents) ────────────────────────────
# 1. Cipta folder dalam Google Drive, cth: "Pemeriksaan JN - Syor"
# 2. Buka folder itu; ID folder ialah bahagian akhir URL:
#    https://drive.google.com/drive/folders/<FOLDER_ID_DI_SINI>
# 3. Cipta service account (console.cloud.google.com → IAM → Service Accounts),
#    muat turun kunci JSON, dan Share folder Drive dengan emel service account.
# 4. Isi kedua-dua nilai di bawah dan tukar USE_MOCK=False dalam gdrive_connector.py.
# Konvensyen nama fail dalam folder: JN_<KOD_SEKOLAH>_<TAHUN>.pdf  (cth. JN_SMK001_2026.pdf)
GDRIVE_FOLDER_ID=
GDRIVE_SERVICE_ACCOUNT_JSON=./secrets/gdrive-sa.json
